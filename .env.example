# JWT 密钥（可用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
SECRET_KEY=your_secret_key_here

# 通义千问 API（用于 AI 评分）
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# CORS 允许的源（开发环境用 *，生产环境填具体域名）
ALLOWED_ORIGINS=*

# 数据库连接（MySQL）
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/civil_interview?charset=utf8mb4

# 如果没有 MySQL，可使用 SQLite（注释掉上面的 DATABASE_URL 即可自动回退）
# DATABASE_URL=sqlite:///./civil_interview.db
